---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { title, summary, status, tech, repo, demo, docs, category } = entry.data;

const sectionRoot =
  category === 'oss' ? 'oss' : category === 'work' ? 'works' : 'blog';
const detailHref = `/${sectionRoot}/${entry.slug}/`;
---
<article class="project-card">
  <header class="project-card-header">
    <h3 class="project-card-title"><a href={detailHref}>{title}</a></h3>
    <span class="project-card-status" data-status={status}>{status}</span>
  </header>
  <p class="project-card-summary">{summary}</p>
  {tech.length > 0 && (
    <ul class="project-card-tech" aria-label="Tech stack">
      {tech.map((t) => <li>{t}</li>)}
    </ul>
  )}
  <ul class="project-card-links" aria-label="Links">
    {repo && <li><a href={repo} rel="noopener" target="_blank">Repo</a></li>}
    {demo && <li><a href={demo} rel="noopener" target="_blank">Demo</a></li>}
    {docs && <li><a href={docs} rel="noopener" target="_blank">Docs</a></li>}
  </ul>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 1.25rem;
    border: 0.5px solid var(--color-border);
    border-radius: 4px;
    background: transparent;
    transition: border-color 0.15s ease-out;
  }
  .project-card:hover {
    border-color: var(--color-text-tertiary);
  }

  .project-card-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
  }

  .project-card-title {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 500;
    line-height: 1.35;
    margin: 0;
    color: var(--color-text-primary);
  }
  .project-card-title a {
    color: inherit;
    text-decoration: none;
  }
  .project-card-title a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .project-card-status {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }
  .project-card-status[data-status='active'] {
    color: var(--color-accent);
  }
  .project-card-status[data-status='archived'] {
    color: var(--color-text-tertiary);
  }

  .project-card-summary {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-text-secondary);
  }

  .project-card-tech {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 12px;
  }
  .project-card-tech li {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary);
  }

  .project-card-links {
    list-style: none;
    margin: 4px 0 0 0;
    padding: 0;
    display: flex;
    gap: 14px;
  }
  .project-card-links a {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .project-card-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
