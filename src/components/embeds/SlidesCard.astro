---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  cover: ImageMetadata;
  pdf: string;          // path under /pdfs/
  title: string;
  event?: string;       // e.g., "IPNTJ 2026 全国大会"
  pages?: number;       // total slide count
  size?: string;        // human-readable, e.g., "9 MB"
}

const { cover, pdf, title, event, pages, size } = Astro.props;

const meta = [
  pages != null ? `${pages} pages` : null,
  size,
  event,
].filter(Boolean).join(' · ');
---
<figure class="slides-card">
  <a class="cover" href={pdf} target="_blank" rel="noopener" aria-label={`Open slides: ${title}`}>
    <Image
      src={cover}
      alt={`${title} — cover slide`}
      widths={[640, 960, 1280]}
      sizes="(min-width: 720px) 640px, 100vw"
      loading="lazy"
    />
    <span class="overlay" aria-hidden="true">View slides →</span>
  </a>

  <figcaption class="meta">
    <p class="eyebrow">Slides</p>
    <p class="title">{title}</p>
    {meta && <p class="sub">{meta}</p>}
    <p class="actions">
      <a href={pdf} target="_blank" rel="noopener">Open →</a>
      <span class="dot" aria-hidden="true">·</span>
      <a href={pdf} download>↓ Download</a>
    </p>
  </figcaption>
</figure>

<style>
  .slides-card {
    margin: 1.5rem 0 2rem 0;
    border: 0.5px solid var(--color-border);
    border-radius: 4px;
    overflow: hidden;
    background: transparent;
  }

  .cover {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    background: var(--color-background-secondary);
    overflow: hidden;
    text-decoration: none;
  }
  .cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease-out;
  }
  .cover:hover :global(img) {
    transform: scale(1.02);
  }
  .cover:hover {
    text-decoration: none;
  }

  .overlay {
    position: absolute;
    right: 12px;
    bottom: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    color: var(--color-bg);
    background: rgba(0, 0, 0, 0.55);
    padding: 6px 10px;
    border-radius: 3px;
    opacity: 0;
    transition: opacity 0.15s ease-out;
    pointer-events: none;
  }
  .cover:hover .overlay,
  .cover:focus-visible .overlay {
    opacity: 1;
  }

  .meta {
    padding: 0.875rem 1.125rem 1rem;
    border-top: 0.5px solid var(--color-border);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 0.25rem 0;
  }
  .title {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.4;
    color: var(--color-text-primary);
    margin: 0 0 0.25rem 0;
  }
  .sub {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--color-text-secondary);
    margin: 0 0 0.5rem 0;
  }
  .actions {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .actions a {
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 0.5px solid var(--color-border);
    padding-bottom: 1px;
    transition: color 0.15s ease-out, border-color 0.15s ease-out;
  }
  .actions a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .dot {
    color: var(--color-text-tertiary);
    margin: 0 6px;
  }
</style>
