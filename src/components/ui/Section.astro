---
interface Props {
  id?: string;
  title?: string;
  eyebrow?: string;
}
const { id, title, eyebrow } = Astro.props;
---
<section id={id}>
  {(eyebrow || title) && (
    <header>
      {eyebrow && <p data-eyebrow>{eyebrow}</p>}
      {title && <h2>{title}</h2>}
    </header>
  )}
  <slot />
</section>
