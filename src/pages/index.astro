---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/layout/SectionLabel.astro';

const sections = [
  {
    href: '/research/',
    eyebrow: 'Research',
    title: 'Publications & talks',
    desc: 'GNSS positioning research — papers and conference talks.',
  },
  {
    href: '/oss/',
    eyebrow: 'OSS',
    title: 'Open source',
    desc: 'Libraries and tools maintained as personal open-source work.',
  },
  {
    href: '/atlas/',
    eyebrow: 'Atlas',
    title: 'Atlas of talks',
    desc: 'A geographic record of where talks have been given.',
  },
  {
    href: '/blog/',
    eyebrow: 'Blog',
    title: 'Notes',
    desc: 'Short essays on positioning, tooling, and travel.',
  },
];
---
<BaseLayout description="GNSS · RESEARCH, ENGINEERING, AND OPEN SOURCE.">
  <section class="hero">
    <p class="hero-role">GNSS · RESEARCH, ENGINEERING, AND OPEN SOURCE</p>
    <h1 class="hero-tagline" lang="ja">
      衛星測位を鳥瞰する
    </h1>
    <p class="hero-tagline-en" lang="en">
      <em>Surveying, thinking, building — across satellite positioning / PNT</em>
    </p>
  </section>

  <section class="sections-toc">
    <SectionLabel as="h2" en="Sections" ja="章立て" />
    <div class="toc-grid">
      {sections.map((s) => (
        <a href={s.href} class="toc-card">
          <span class="toc-eyebrow">{s.eyebrow}</span>
          <span class="toc-title">{s.title}</span>
          <span class="toc-desc">{s.desc}</span>
          <span class="toc-cta">Browse →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    margin: 2.5rem 0 3rem 0;
  }
  .hero-role {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 1.25rem 0;
  }
  .hero-tagline {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.005em;
    margin: 0 0 0.75rem 0;
    color: var(--color-text-primary);
  }
  .hero-tagline-en {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 400;
    font-style: italic;
    line-height: 1.5;
    margin: 0;
    color: var(--color-text-secondary);
  }
  @media (max-width: 640px) {
    .hero-tagline {
      font-size: 26px;
    }
  }

  .sections-toc {
    margin: 3rem 0;
  }
  .toc-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 640px) {
    .toc-grid {
      grid-template-columns: 1fr;
    }
  }
  .toc-card {
    display: grid;
    gap: 8px;
    padding: 1.25rem 1.25rem 1.25rem 1.25rem;
    border: 0.5px solid var(--color-border);
    border-radius: 4px;
    color: inherit;
    text-decoration: none;
    background: transparent;
    transition: border-color 0.15s ease-out, background-color 0.15s ease-out;
  }
  .toc-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }
  .toc-card:hover .toc-cta {
    color: var(--color-accent);
  }
  .toc-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }
  .toc-title {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-text-primary);
  }
  .toc-desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-text-secondary);
  }
  .toc-cta {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    color: var(--color-text-secondary);
    transition: color 0.15s ease-out;
  }
</style>
