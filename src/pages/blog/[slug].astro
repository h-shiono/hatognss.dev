---
import { getCollection, type CollectionEntry } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('blog', (e) => !e.data.draft);
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'blog'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, date, updatedDate, language } = entry.data;
---
<BlogLayout
  title={title}
  description={description}
  date={date}
  updatedDate={updatedDate}
  language={language}
>
  <Content />
</BlogLayout>
