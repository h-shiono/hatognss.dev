---
import { getCollection, getEntry, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import InsetMap from '../../../components/atlas/InsetMap.astro';
import { formatDate } from '../../../lib/utils';

export async function getStaticPaths() {
  const entries = await getCollection('talks');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'talks'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
const {
  title,
  event,
  date,
  location,
  type,
  slides_url,
  slides_pdf,
  video_url,
  url,
  abstract,
  tags,
  lat,
  lng,
  related_publication,
} = entry.data;

const relatedPublication = related_publication
  ? await getEntry(related_publication)
  : undefined;
---
<BaseLayout title={title} description={abstract}>
  <article class="detail">
    <header class="detail-header">
      <p class="eyebrow">Talk</p>
      <h1 class="title">{title}</h1>
      <p class="event">
        {event}
        {location && <><span class="dot" aria-hidden="true">·</span>{location}</>}
      </p>

      <dl class="meta">
        <div>
          <dt>Date</dt>
          <dd><time datetime={date.toISOString()}>{formatDate(date)}</time></dd>
        </div>
        <div>
          <dt>Type</dt>
          <dd>{type}</dd>
        </div>
      </dl>

      {(slides_url || slides_pdf || video_url || url) && (
        <ul class="link-bar" aria-label="Talk materials">
          {slides_url && <li><a href={slides_url} rel="noopener" target="_blank">Slides →</a></li>}
          {slides_pdf && <li><a href={slides_pdf} rel="noopener" target="_blank">PDF →</a></li>}
          {video_url && <li><a href={video_url} rel="noopener" target="_blank">Video →</a></li>}
          {url && <li><a href={url} rel="noopener" target="_blank">Event →</a></li>}
        </ul>
      )}

      {relatedPublication && (
        <aside class="related" aria-label="Related publication">
          <p class="related-label">Related publication</p>
          <a class="related-link" href={`/research/publications/${relatedPublication.slug}/`}>
            <span class="related-title">{relatedPublication.data.title}</span>
            <span class="related-meta">
              <em>{relatedPublication.data.venue}</em>, {relatedPublication.data.year}
            </span>
          </a>
        </aside>
      )}

      {tags.length > 0 && (
        <ul class="tags" aria-label="Tags">
          {tags.map((t) => <li>{t}</li>)}
        </ul>
      )}
    </header>

    {lat != null && lng != null && (
      <section class="map-wrap">
        <InsetMap lat={lat} lng={lng} label={location} />
      </section>
    )}

    <section class="abstract prose">
      <p>{abstract}</p>
    </section>

    <section class="body prose">
      <Content />
    </section>
  </article>
</BaseLayout>

<style>
  .detail {
    max-width: 720px;
    margin: 0 auto;
  }
  .detail-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--color-border);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    margin: 0 0 0.75rem 0;
  }
  .title {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 0.75rem 0;
  }
  .event {
    font-family: var(--font-display);
    font-size: 17px;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0 0 1.5rem 0;
  }
  .dot {
    color: var(--color-text-tertiary);
    margin: 0 6px;
  }
  .meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.75rem 1.5rem;
    margin: 1.5rem 0 0 0;
    padding: 0;
  }
  .meta div {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .meta dt {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin: 0;
  }
  .meta dd {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .link-bar {
    list-style: none;
    margin: 1.5rem 0 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }
  .link-bar a {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 0.5px solid var(--color-border);
    padding-bottom: 2px;
    transition: color 0.15s ease-out, border-color 0.15s ease-out;
  }
  .link-bar a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .tags {
    list-style: none;
    margin: 1rem 0 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 12px;
  }
  .tags li {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-secondary);
  }
  .related {
    margin: 1.5rem 0 0 0;
    padding: 1rem 1.25rem;
    border: 0.5px solid var(--color-border);
    border-radius: 4px;
    background: transparent;
  }
  .related-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin: 0 0 0.5rem 0;
  }
  .related-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-decoration: none;
    color: inherit;
  }
  .related-link:hover {
    text-decoration: none;
  }
  .related-link:hover .related-title {
    color: var(--color-accent);
  }
  .related-title {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.4;
    color: var(--color-text-primary);
    transition: color 0.15s ease-out;
  }
  .related-meta {
    font-size: 13px;
    color: var(--color-text-secondary);
  }
  .related-meta em {
    font-style: italic;
  }
  .map-wrap {
    margin: 0 0 2.5rem 0;
  }
  .abstract {
    margin: 0 0 2.5rem 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }
  .body {
    margin: 0;
  }
</style>
