---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectDetailHeader from '../../components/layout/ProjectDetailHeader.astro';

export async function getStaticPaths() {
  const entries = await getCollection('projects', (e) => e.data.category === 'work');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

interface Props { entry: CollectionEntry<'projects'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="detail">
    <ProjectDetailHeader entry={entry} eyebrow="Works" />
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .detail {
    max-width: 720px;
    margin: 0 auto;
  }
</style>
