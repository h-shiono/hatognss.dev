---
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import AtlasMap from '../components/atlas/AtlasMap';
import type { AtlasMarker } from '../components/atlas/AtlasMap';
import AtlasList from '../components/atlas/AtlasList.astro';
import { getLandFeatures } from '../lib/atlas/worldTopology';
import {
  ATLAS_HEIGHT,
  ATLAS_WIDTH,
  getGraticule,
  makePathGenerator,
  makeProjection,
} from '../lib/atlas/projection';

const projection = makeProjection();
const pathGen = makePathGenerator(projection);

const landPath = pathGen(getLandFeatures()) ?? '';
const graticulePath = pathGen(getGraticule()) ?? '';

const allTalks = await getCollection('talks');

const mappableTalks = allTalks.filter(
  (t) => t.data.lat != null && t.data.lng != null,
);

const markers: AtlasMarker[] = await Promise.all(
  mappableTalks.map(async (t) => {
    // Filter above guarantees these are present.
    const [x, y] = projection([t.data.lng!, t.data.lat!]) ?? [0, 0];

    let thumbnailSrc: string | undefined;
    let thumbnailAlt: string | undefined;
    if (t.data.thumbnail) {
      const optimized = await getImage({
        src: t.data.thumbnail,
        width: 220,
        height: 130,
      });
      thumbnailSrc = optimized.src;
      thumbnailAlt = `${t.data.location ?? ''} — ${t.data.event}`;
    }

    return {
      slug: t.slug,
      x,
      y,
      title: t.data.title,
      event: t.data.event,
      dateISO: t.data.date.toISOString(),
      location: t.data.location ?? '',
      type: t.data.type,
      thumbnailSrc,
      thumbnailAlt,
    };
  }),
);

// Year range header. Uses all talks (not just mappable).
const years = allTalks
  .map((t) => t.data.date.getUTCFullYear())
  .sort((a, b) => a - b);
const yearLabel =
  years.length === 0
    ? ''
    : years[0] === years[years.length - 1]
      ? `${years[0]}`
      : `${years[0]} — ${years[years.length - 1]}`;
---

<BaseLayout
  title="Atlas"
  description="A geographic atlas of talks given by hato.GNSS."
>
  <article class="atlas-page">
    <header class="atlas-header">
      <h1 class="atlas-title">
        Talks <span class="atlas-sep">·</span> Atlas
        {yearLabel && <span class="atlas-year">/ {yearLabel}</span>}
      </h1>
    </header>

    <section class="atlas-section">
      <h2 class="atlas-section-heading">
        <span lang="ja">地図</span>
        <span class="atlas-sep">·</span>
        <span lang="en">Map</span>
      </h2>
      <div class="atlas-map-wrapper">
        <AtlasMap
          client:visible
          landPath={landPath}
          graticulePath={graticulePath}
          width={ATLAS_WIDTH}
          height={ATLAS_HEIGHT}
          markers={markers}
        />
      </div>
    </section>

    <section class="atlas-section">
      <h2 class="atlas-section-heading">
        <span lang="ja">一覧</span>
        <span class="atlas-sep">·</span>
        <span lang="en">List</span>
      </h2>
      <AtlasList talks={allTalks} />
    </section>
  </article>
</BaseLayout>

<style>
  .atlas-page {
    max-width: 920px;
    margin: 0 auto;
    padding: 48px 24px 96px;
  }

  .atlas-header {
    margin-bottom: 48px;
  }

  .atlas-title {
    font-size: 28px;
    font-weight: 500;
    margin: 0;
    color: var(--color-foreground);
    letter-spacing: -0.01em;
  }

  .atlas-year {
    font-family: var(--font-mono);
    font-weight: 400;
    color: var(--color-foreground-muted);
    margin-left: 8px;
  }

  .atlas-sep {
    color: var(--color-foreground-muted);
    margin: 0 6px;
    font-weight: 400;
  }

  .atlas-section {
    margin-top: 48px;
  }

  .atlas-section-heading {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-foreground-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 16px 0;
    padding-bottom: 8px;
    border-bottom: 0.5px solid var(--color-border-tertiary);
  }

  .atlas-map-wrapper {
    margin: 0;
  }
</style>
